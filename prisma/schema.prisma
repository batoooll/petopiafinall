// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

generator erd {
  provider = "prisma-erd-generator"
  output   = "./ERD.svg"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PET_OWNER
  VET
  ADMIN
}

enum Gender {
  MALE
  FEMALE
}

enum PaymentMethod {
  INSTAPAY
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum MatchRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  fullName     String
  age          Int
  role         UserRole
  createdAt    DateTime @default(now())
  gender       Gender

  //relations
  ownerProfile   PetOwnerProfile?
  vetProfile     VetProfile?
  uploadedAssets Asset[]          @relation("AssetsUploadedBy")

  // Pets (only for PET_OWNER)
  pets                Pet[]
  appointmentsAsOwner Appointment[] @relation("OwnerAppointments")
  appointmentsAsVet   Appointment[] @relation("VetAppointments")

  payments Payment[] @relation("PaymentsByUser")

  sittingListings Services[]   @relation("ListingsBySitter")
  sittingBookings PetSitting[] @relation("BookingsByOwner")

  conversationParticipants ConversationParticipant[]
  sentMessages             ChatMessage[]             @relation("SentMessages")

  availabilitySlots VetAvailabilitySlot[]
  medicalRecords    MedicalRecord[]
  recognitionLogs   PetRecognitionLog[]
  adminActions      AdminActionLog[]
}

model PetOwnerProfile {
  id     String @id @default(cuid())
  userId String @unique
  phone  String

  /////relations
  user         User          @relation(fields: [userId], references: [id])
  pets         Pet[]
  appointments Appointment[]
  payments     Payment[]
}

model VetProfile {
  id                 String             @id @default(cuid())
  userId             String             @unique
  phone              String
  description        String?
  yearsOfExperience  Int
  certificateUrl     String
  verificationStatus VerificationStatus @default(PENDING)

  clinicId String

  user   User   @relation(fields: [userId], references: [id])
  clinic Clinic @relation(fields: [clinicId], references: [id])
}

model Clinic {
  id      String @id @default(cuid())
  name    String
  address String
  phone   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  vets              VetProfile[]
  availabilitySlots VetAvailabilitySlot[]
}

model Pet {
  id      String @id @default(cuid())
  ownerId String @unique // Add @unique constraint

  // Relations
  owner             User                @relation(fields: [ownerId], references: [id])
  images            PetImage[]
  matchProfile      PetMatchProfile?
  medicalRecords    MedicalRecord[]
  appointments      Appointment[]
  sittingBookings   PetSitting[]
  servicesForPet    Services[]          @relation("ServicesForPet") // Add this
  recognitionLogs   PetRecognitionLog[]
  matchRequestsFrom PetMatchRequest[]   @relation("MatchFromPet")
  matchRequestsTo   PetMatchRequest[]   @relation("MatchToPet")
  petOwnerProfile   PetOwnerProfile?    @relation(fields: [petOwnerProfileId], references: [id])
  petOwnerProfileId String?
}

model PetImage {
  id        String   @id @default(cuid())
  petId     String
  assetId   String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  /////relations
  pet   Pet   @relation(fields: [petId], references: [id])
  asset Asset @relation(fields: [assetId], references: [id])

  @@unique([petId, assetId])
  @@index([petId])
}

model PetRecognitionLog {
  id                String   @id @default(cuid())
  userId            String
  petId             String?
  inputAssetId      String
  detectedBreed     String?
  detectedAgeMonths Int?
  createdAt         DateTime @default(now())

  /////relations
  user       User  @relation(fields: [userId], references: [id])
  pet        Pet?  @relation(fields: [petId], references: [id])
  inputAsset Asset @relation("RecognitionInput", fields: [inputAssetId], references: [id])

  @@index([userId, createdAt])
}

model MedicalRecord {
  id            String  @id @default(cuid())
  petId         String
  vetId         String
  appointmentId String?

  visitDate DateTime @default(now())
  diagnosis String?
  treatment String?
  notes     String?

  //////relations
  pet         Pet          @relation(fields: [petId], references: [id])
  vet         User         @relation(fields: [vetId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([petId, visitDate])
}

model VetAvailabilitySlot {
  id       String  @id @default(cuid())
  vetId    String
  clinicId String?

  startTime DateTime
  endTime   DateTime
  isActive  Boolean  @default(true)

  ///relations
  vet    User    @relation(fields: [vetId], references: [id], onDelete: Cascade)
  clinic Clinic? @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  @@index([vetId, startTime])
}

model Appointment {
  id      String @id @default(cuid())
  ownerId String
  vetId   String
  petId   String

  clinicName    String?
  clinicAddress String?

  startTime DateTime
  status    AppointmentStatus @default(PENDING)
  reason    String?
  Price     Int

  createdAt DateTime @default(now())

  //relations
  owner User @relation("OwnerAppointments", fields: [ownerId], references: [id])
  vet   User @relation("VetAppointments", fields: [vetId], references: [id])
  pet   Pet  @relation(fields: [petId], references: [id])

  payment           Payment?         @relation("AppointmentPayment")
  medicalRecords    MedicalRecord[]
  petOwnerProfile   PetOwnerProfile? @relation(fields: [petOwnerProfileId], references: [id])
  petOwnerProfileId String?

  @@index([vetId, startTime])
  @@index([ownerId, startTime])
}

model Services {
  id       String @id @default(cuid())
  sitterId String
  petid    String

  title       String
  description String?
  address     String
  pricePerDay Int?
  ServiceName String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sitter   User         @relation("ListingsBySitter", fields: [sitterId], references: [id])
  pet      Pet          @relation("ServicesForPet", fields: [petid], references: [id])
  bookings PetSitting[]

  @@index([sitterId])
  @@index([petid])
}

model PetSitting {
  id          String        @id @default(cuid())
  listingId   String
  petOwnerId  String
  petId       String
  currency    String?
  startTime   DateTime
  endTime     DateTime
  status      BookingStatus @default(PENDING)
  totalAmount Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing  Services @relation(fields: [listingId], references: [id], onDelete: Cascade)
  petOwner User     @relation("BookingsByOwner", fields: [petOwnerId], references: [id], onDelete: Cascade)
  pet      Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)

  payment Payment? @relation("SittingPayment")

  @@index([petOwnerId, startTime])
  @@index([listingId, startTime])
}

model Payment {
  id String @id @default(cuid())

  appointmentId    String? @unique
  sittingBookingId String? @unique
  payerId          String

  method PaymentMethod @default(INSTAPAY)
  status PaymentStatus @default(PENDING)

  amount   Int
  currency String @default("EGP")

  // Screenshot proof (uploaded file)
  proofAssetId String?
  proofAsset   Asset?  @relation(fields: [proofAssetId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payer             User             @relation("PaymentsByUser", fields: [payerId], references: [id])
  appointment       Appointment?     @relation("AppointmentPayment", fields: [appointmentId], references: [id], onDelete: Cascade)
  sittingBooking    PetSitting?      @relation("SittingPayment", fields: [sittingBookingId], references: [id], onDelete: Cascade)
  petOwnerProfile   PetOwnerProfile? @relation(fields: [petOwnerProfileId], references: [id])
  petOwnerProfileId String?

  @@index([payerId, createdAt])
  @@index([status, createdAt])
}

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     ChatMessage[]
}

model ConversationParticipant {
  id             String @id @default(cuid())
  conversationId String
  userId         String

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model ChatMessage {
  id             String  @id @default(cuid())
  conversationId String
  senderId       String
  content        String?
  assetId        String?

  createdAt DateTime  @default(now())
  readAt    DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  asset        Asset?       @relation("MessageAsset", fields: [assetId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
}

model PetMatchProfile {
  id    String @id @default(cuid())
  petId String @unique

  description    String?
  address        String?
  preferredBreed String?
  isavailable    Boolean @default(true)

  pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)
}

model PetMatchRequest {
  id        String             @id @default(cuid())
  fromPetId String
  toPetId   String
  status    MatchRequestStatus @default(PENDING)
  createdAt DateTime           @default(now())

  fromPet Pet @relation("MatchFromPet", fields: [fromPetId], references: [id], onDelete: Cascade)
  toPet   Pet @relation("MatchToPet", fields: [toPetId], references: [id], onDelete: Cascade)

  @@unique([fromPetId, toPetId])
  @@index([toPetId, status])
}

model SharedResources {
  id          String  @id @default(cuid())
  title       String
  description String?
  url         String
  isFree      Boolean @default(true)

  createdAt DateTime @default(now())

  tags ResourceTag[]
}

model Tag {
  id   String @id @default(cuid())
  name String @unique

  resources ResourceTag[]
}

model ResourceTag {
  id         String @id @default(cuid())
  resourceId String
  tagId      String

  resource SharedResources @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  tag      Tag             @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([resourceId, tagId])
}

model Asset {
  id         String  @id @default(cuid())
  url        String
  mimeType   String?
  sizeBytes  Int?
  storageKey String? @unique

  uploadedById String?
  createdAt    DateTime @default(now())

  uploadedBy User? @relation("AssetsUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  petImages         PetImage[]
  recognitionInputs PetRecognitionLog[] @relation("RecognitionInput")
  messageAssets     ChatMessage[]       @relation("MessageAsset")
  paymentProofs     Payment[]
}

model AdminActionLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  entityType String?
  entityId   String?
  meta       Json?
  createdAt  DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, createdAt])
}
